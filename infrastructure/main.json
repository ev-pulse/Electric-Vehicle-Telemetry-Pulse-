{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "4073990694329093086"
    }
  },
  "parameters": {
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment — dev/staging/prod"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "koreacentral",
      "metadata": {
        "description": "Azure region — 파이프라인 레이턴시 최소화를 위해 koreacentral 고정"
      }
    },
    "projectPrefix": {
      "type": "string",
      "defaultValue": "evpulse",
      "metadata": {
        "description": "Project prefix — 모든 리소스명 앞에 붙는 식별자"
      }
    },
    "iotHubSku": {
      "type": "string",
      "defaultValue": "S1",
      "allowedValues": [
        "F1",
        "S1"
      ],
      "metadata": {
        "description": "IoT Hub SKU — S1: 팀 프로젝트 / F1: 개인 테스트용 무료"
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "sqluser",
      "metadata": {
        "description": "Azure SQL administrator login name"
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Azure SQL administrator password"
      }
    },
    "saStreamingUnits": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Stream Analytics Streaming Units — 1이 최소, 비용 최소"
      }
    },
    "alertEmailAddress": {
      "type": "string",
      "metadata": {
        "description": "비용 알림 수신 이메일 주소"
      }
    },
    "teamsWebhookUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Teams Incoming Webhook URL — 비용 알림 채널"
      }
    }
  },
  "variables": {
    "iotHubName": "[format('{0}-iothub-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "sqlServerName": "[format('{0}-sqlserver-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "sqlDbName": "[format('{0}-db-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "saJobName": "[format('{0}-sa-job-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "logicAppName": "[format('{0}-logic-app-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "storageAccountName": "[format('{0}storage{1}', parameters('projectPrefix'), parameters('environment'))]",
    "actionGroupName": "[format('{0}-cost-ag-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "policyAssignmentName": "[format('{0}-allowed-vm-skus-{1}', parameters('projectPrefix'), parameters('environment'))]",
    "allowedVmSkuPolicyId": "/providers/Microsoft.Authorization/policyDefinitions/cccc23c7-8427-4f53-ad12-b6a63eb452b3"
  },
  "resources": [
    {
      "type": "Microsoft.Devices/IotHubs",
      "apiVersion": "2021-07-02",
      "name": "[variables('iotHubName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('iotHubSku')]",
        "capacity": 1
      },
      "properties": {
        "eventHubEndpoints": {
          "events": {
            "retentionTimeInDays": 1,
            "partitionCount": 2
          }
        },
        "routing": {
          "fallbackRoute": {
            "name": "$fallback",
            "source": "DeviceMessages",
            "condition": "true",
            "endpointNames": [
              "events"
            ],
            "isEnabled": true
          }
        },
        "cloudToDevice": {
          "maxDeliveryCount": 10,
          "defaultTtlAsIso8601": "PT1H"
        },
        "minTlsVersion": "1.2",
        "disableLocalAuth": false
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "ingestion"
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "version": "12.0",
        "minimalTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled"
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "storage"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2022-05-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDbName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "S0",
        "tier": "Standard"
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": 268435456000
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "storage"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2022-05-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.StreamAnalytics/streamingjobs",
      "apiVersion": "2021-10-01-preview",
      "name": "[variables('saJobName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "Standard"
        },
        "eventsOutOfOrderPolicy": "Adjust",
        "outputErrorPolicy": "Stop",
        "eventsOutOfOrderMaxDelayInSeconds": 5,
        "eventsLateArrivalMaxDelayInSeconds": 5,
        "dataLocale": "en-US",
        "compatibilityLevel": "1.2",
        "jobType": "Cloud"
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "processing",
        "note": "I/O configured separately — see /sql/sa_query.sql"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2022-09-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "accessTier": "Hot"
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "runtime-storage"
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[variables('logicAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "triggers": {},
          "actions": {}
        },
        "parameters": {}
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "alerting",
        "trigger": "SharePoint When-an-item-is-created (V2)",
        "action": "Teams 채팅 또는 채널에서 메시지 게시"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers/databases', variables('sqlServerName'), variables('sqlDbName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[variables('actionGroupName')]",
      "location": "global",
      "properties": {
        "groupShortName": "EVCostAlert",
        "enabled": true,
        "emailReceivers": [
          {
            "name": "CostAlertPrimaryEmail",
            "emailAddress": "[parameters('alertEmailAddress')]",
            "useCommonAlertSchema": true
          }
        ],
        "webhookReceivers": [
          {
            "name": "TeamsIncomingWebhook",
            "serviceUri": "[parameters('teamsWebhookUrl')]",
            "useCommonAlertSchema": true,
            "useAadAuth": false
          }
        ]
      },
      "tags": {
        "project": "ev-pulse",
        "environment": "[parameters('environment')]",
        "role": "cost-governance",
        "channels": "email + teams-webhook"
      }
    },
    {
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2022-06-01",
      "name": "[variables('policyAssignmentName')]",
      "properties": {
        "policyDefinitionId": "[variables('allowedVmSkuPolicyId')]",
        "displayName": "EV-Pulse: Allowed VM Size SKUs",
        "description": "Cost governance — restricts VM creation to B-series and D2s_v3 SKUs. Violations logged to Azure Monitor. Switch enforcementMode to Default to enforce Deny.",
        "enforcementMode": "DoNotEnforce",
        "parameters": {
          "listOfAllowedSKUs": {
            "value": [
              "Standard_B1s",
              "Standard_B1ms",
              "Standard_B2s",
              "Standard_B2ms",
              "Standard_D2s_v3"
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "iotHubName": {
      "type": "string",
      "value": "[variables('iotHubName')]"
    },
    "iotHubResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Devices/IotHubs', variables('iotHubName'))]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2022-05-01-preview').fullyQualifiedDomainName]"
    },
    "sqlDbName": {
      "type": "string",
      "value": "[variables('sqlDbName')]"
    },
    "saJobName": {
      "type": "string",
      "value": "[variables('saJobName')]"
    },
    "logicAppName": {
      "type": "string",
      "value": "[variables('logicAppName')]"
    },
    "actionGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/actionGroups', variables('actionGroupName'))]"
    },
    "policyAssignmentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Authorization/policyAssignments', variables('policyAssignmentName'))]"
    },
    "deploymentSummary": {
      "type": "object",
      "value": {
        "author": "Dana Kim",
        "environment": "[parameters('environment')]",
        "location": "[parameters('location')]",
        "resources": [
          "[format('IoT Hub ({0})', parameters('iotHubSku'))]",
          "SQL Server + Database (S0 / 10DTU)",
          "[format('Stream Analytics Job (SU: {0})', parameters('saStreamingUnits'))]",
          "Storage Account (Standard_LRS)",
          "Logic Apps (SharePoint → Teams)",
          "Action Group (email + Teams webhook)",
          "Policy Assignment — Allowed VM SKUs (Audit)"
        ],
        "costGovernance": {
          "budget": "학교 설정 ₩400,000/월 (4dt_team_1 RG 스코프) 활용",
          "alertChannels": "email + Teams Incoming Webhook",
          "vmSkuPolicy": "Audit — B-series + D2s_v3 allowed"
        }
      }
    }
  }
}